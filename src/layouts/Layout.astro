---

import SideBar from "../components/SideBar.astro";
import Header from "../components/Header.astro";

const url = import.meta.env.PUBLIC_WEBSITE_URL;

---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Robot flywheel launcher physics visualizer app for FTC season DECODE"/>
		<meta name="generator" content={Astro.generator} />

		<meta property="og:title" content="SimLaunch" />
		<meta property="og:description" content="Interactive flywheel launcher physics visualizer for FTC DECODE" />
        <meta property="og:image" content=`${url}/simlaunch_screenshot.png` />
        <meta property="og:url" content=`${url}` />
		<meta property="og:type" content="website" />

		<link rel="icon" href="favicon.ico" sizes="64x64">
        <link rel="canonical" href=`${url}` />

		<title>SimLaunch</title>
	</head>
	<body>
        <div class="flex flex-row h-full w-full m-0 p-0 text-clk-text-primary overflow-hidden">
            <SideBar/>

            <div class="flex flex-col size-full m-0 p-0 bg-clk-background" id="contents">
                <Header/>

                <div class="flex flex-row justify-center h-full w-full" id="main-container">

	                <slot />

                </div>
            </div>
        </div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
