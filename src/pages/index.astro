---
import Layout from '../layouts/Layout.astro';
import "../styles/global.css";

import Header from '../components/Header';
import SidePlots from "../components/SidePlots";
import FlywheelSlider from "../components/FlywheelSlider";
import CompassSlider from "../components/CompassSlider";
---

<Layout>
    <div class="flex flex-col h-screen w-screen m-0 p-0
            bg-clk-background text-clk-text-primary" id="background">
        <Header/>
        <div class="flex flex-row justify-center h-full w-full" id="main-container">
            <main class="flex flex-col justify-center h-full max-w-360 w-full" id="content">
                <SidePlots client:only/>
                <section class="h-60 w-full flex justify-center items-center">
                    <FlywheelSlider client:load/>
                    <CompassSlider client:load/>
                </section>
            </main>
        </div>
    </div>
</Layout>
