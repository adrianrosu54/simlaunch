---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

import Card from "../components/Card";

import SideBarToggle from "../components/buttons/SideBarToggle";
import ViewToggle from "../components/buttons/ViewToggle";
import ConfigSettings from "../components/settings/ConfigSettings";

import FieldPlots from "../components/FieldPlots";
import SidePlots from "../components/SidePlots";
import FlywheelSlider from "../components/FlywheelSlider";
import CompassSlider from "../components/CompassSlider";
import ErrorBar from '../components/ErrorBar';
import ImpactReading from '../components/ImpactCard';

---

<Layout>
    <div class="flex flex-row h-full w-full m-0 p-0 text-clk-text-primary overflow-hidden">
        <aside class="fixed lg:relative left-0 z-50 w-0 min-w-0 h-full transition-all duration-300 ease-in-out
                flex flex-col justify-start overflow-hidden" 
                id="sidebar">
            <div class="absolute top-0 right-0 h-full w-screen md:w-full
                    flex flex-col justify-start bg-clk-secondary overflow-hidden whitespace-nowrap"
                    id="sidebar-inner">
                <div class="flex flex-row justify-end py-2 max-h-14 border-b-2 border-clk-text-secondary/20">
                    <SideBarToggle client:load type="close"/>
                </div>
                
                <div class="overflow-y-auto sidebar-scrollbar">
                    <ConfigSettings client:load />
                </div>
            </div>
        </aside>

        <div class="flex flex-col size-full m-0 p-0 bg-clk-background" id="contents">
            <header class="flex flex-row justify-between max-h-14 p-1 bg-clk-primary border-b-2 border-clk-accent">
                <div class="p-2">
                    <SideBarToggle client:load type="open" />
                </div>
                <h1 class="text-2xl font-bold text-center">SimLaunch</h1>
                <div class="p-2">
                    <ViewToggle client:load/>
                </div>
            </header>

            <div class="flex flex-row justify-center h-full w-full" id="main-container">
                <main class="grid grid-cols-2 grid-rows-4 md:grid-cols-4 md:grid-rows-3 max-w-320 w-full h-full gap-0" 
                        id="content">
                    <FieldPlots client:only/>
                    <SidePlots client:only/>
                    
                    <Card className="not-md:order-last col-span-1 row-span-1">
                        <div class="flex flex-row justify-between size-full">
                            <ErrorBar client:load/>
                            <ImpactReading client:load/>
                        </div>
                    </Card>

                    <Card className="col-span-2 row-span-1">
                        <div class="h-full w-full grid grid-cols-2 grid-rows-1 overflow-hidden">
                            <FlywheelSlider client:load/>
                            <CompassSlider client:load/>
                        </div>
                    </Card>
                </main>
            </div>
        </div>
    </div>
    <script>
        import { $isSidebarOpen } from "../stores/settings";
        const sidebar = document.getElementById("sidebar");

        $isSidebarOpen.subscribe((isOpen) => {
            if (isOpen) {
                sidebar?.classList.toggle("md:w-66", true);
                sidebar?.classList.toggle("w-full", true);
                sidebar?.classList.toggle("w-0", false);
            } else {
                sidebar?.classList.toggle("md:w-66", false);
                sidebar?.classList.toggle("w-full", false);
                sidebar?.classList.toggle("w-0", true);
            }
        })
    </script>
</Layout>
